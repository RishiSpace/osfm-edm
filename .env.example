# Server
DATABASE_URL=postgres://osfm_edm:secret@localhost:5432/osfm_edm
JWT_SECRET=change_me_to_a_long_random_string_at_least_64_chars
SERVER_PORT=8080
AGENT_PORT=8443
SERVER_URL=https://osfm-edm.local

# First-boot admin account (used only if no users exist in DB)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_immediately

# TLS (optional — if not set, server generates self-signed)
TLS_CERT_PATH=
TLS_KEY_PATH=

# Notifications (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=osfm_edm@yourdomain.com

# Dashboard (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
